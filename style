body {
    font-family: Arial;
    margin: 0;
}

/* header at the top of page */
h1 {
    font: Calibri
    font-size: 35px;
    font-weight: 800;
    color: #f2f2f2;
    background-color: #5a0a8a; 
    padding: 15px 20px;
    margin: 0;
}


/* Navigation items in the header at top of page - menu etc */
.nav span {
    color: white;
    margin-left: 10px;
    margin-right: 50px;
    font-size: 20px; 
  }

.header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    background-color: #5a0a8a;
    padding: 15px 20px;
}


/* The menu list */
ul {
    color: indigo;
    margin: 0;
    font-weight: bold;
    font-size: 14px;
   text-align:center;
   list-style-position: inside;
   padding-left:0;
}

.menu {
    background-color: white;
    padding: 20px 40px;
    list-style-type: square;
    display: grid;              
    grid-template-columns: 1fr 1fr; 
    gap: 10px 50px;     
       

}

.menu li {
    padding: 10px;
    background-color: #e6dded;
    border-radius: 5px;
}

/* hover effect */
.menu li:hover {
    background-color: #dcd0e6; 
}



/* Burger section (hero) */
.hero {
    display: flex;
    justify-content: space-between;
    align-items: center;
    background-color: #e6dded;
    padding: 20px 150px;
    color: #5a0a8a;
}

.hero-text {
    max-width: 50%;   /*adding this to limit the text inside a text box */
}

.hero-text h2 {
    font-size: 42px;
    margin-bottom: 10px;
}

.hero-text h3 {
    font-size: 24px;
    margin-bottom: 15px;
}

.hero-text p {
    font-size: 15px;
    line-height: 1.5;
    margin-bottom: 25px;
}

/* Image of the burger in the hero */
.hero-image img {
    width: 350px;
    padding-right: 100px;
}


/* the nuritional table - general layout */
table {
    width: 80%;
    margin: 40px auto;
    border-collapse: collapse;
    background-color: white;
    border-radius: 8px;
    overflow: hidden;
}

/* Top part of the table */
th {
    background-color: #5a0a8a;
    color: white;
    padding: 15px;
    font-size: 18px;
}

/* each table cell */
td {
    padding: 12px;
    text-align: center;
    font-size: 14px;
    color: #5a0a8a;
    border-bottom: 1px solid grey;
}

/* application of hover effect */
tr:hover {
    background-color: #e6dded;
}


/*the bottom bar of the webpage*/

.bottombar {
 background-color: #5a0a8a;
 color: #f2f2f2;
 padding: 5px 20px;
 margin: 0;
 text-align: center;

}
